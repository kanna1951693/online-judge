# ==============================================================================
# Git Ignore Configuration - Sandboxed Online Judge Monorepo
# ==============================================================================

# ------------------------------------------------------------------------------
# OS and System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# IDEs and Editors
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# Node/React (Frontend)
# ------------------------------------------------------------------------------
# Dependency directory
frontend/node_modules/
node_modules/

# Production build output
frontend/dist/
frontend/build/
dist/
build/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Next.js/Vite cache and local configs
frontend/.next/
frontend/.svelte-kit/
frontend/.turbo/
.eslintcache
.parcel-cache

# ------------------------------------------------------------------------------
# Python/FastAPI (Backend & Sandbox)
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
