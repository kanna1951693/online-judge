# Secret & Environment Files
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
