# ──────────────────────────────────────────────────────────────
# ApexJudge Frontend – environment variables
# Copy this file to .env.local and fill in real values.
# ──────────────────────────────────────────────────────────────

# Backend API base URL (leave empty for local dev — Vite proxies /api to localhost:8000)
# Production (Vercel): set to your deployed backend, e.g. https://apexjudge-api.onrender.com
VITE_API_URL=

# Supabase project URL  (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon key  (Project Settings → API → anon / public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
