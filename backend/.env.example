# ──────────────────────────────────────────────────────────────
# ApexJudge Backend – environment variables
# Copy to backend/.env or project-root .env.local and fill in values.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase session-mode pooler or local)
# Supabase: Project Settings → Database → Connection String → Session pooler (port 5432)
# IMPORTANT: URL-encode any special chars in your password (e.g. @ → %40)
# Example format (do NOT commit real credentials):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+psycopg2://apexjudge:apexjudge_secret@localhost:5432/apexjudge

# Direct connection to the database (used for migrations if different from DATABASE_URL)
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# Redis (required for submission queue)
REDIS_URL=redis://localhost:6379/0

# Supabase project URL  (Project Settings → API → Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon/publishable key  (Project Settings → API)
# Used by /api/v1/auth/supabase-login to validate Supabase access tokens
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase JWT Secret (Project Settings → API → JWT Settings → JWT Secret)
# Used to verify incoming Supabase Auth JWTs locally on the backend
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Local JWT secret (used for app-internal tokens after login)
JWT_SECRET_KEY=apexjudge-dev-secret-key-change-in-prod

# Optional: filesystem paths (defaults work for local dev and Docker)
# PROBLEMS_JSON_PATH=/app/backend/app/problems.json
# PROBLEMS_DIR=/app/backend/problems
# SANDBOX_TEMP_DIR=/app/backend/temp/submissions
# SANDBOX_LIB_DIR=/app/backend/sandbox/lib
# HOST_WORKSPACE_PATH=/app
